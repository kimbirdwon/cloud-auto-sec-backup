{
  "annotations": { "list": [ { "builtIn": 1, "datasource": { "type": "grafana", "uid": "-- Grafana --" }, "enable": true, "hide": true, "name": "Annotations & Alerts", "type": "dashboard" } ] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "max": 100, "min": 0, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": 0 }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 } ] }, "unit": "percent" }
      },
      "gridPos": { "h": 9, "w": 6, "x": 0, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "targets": [
        {
          "expr": "(1 - avg(irate(node_cpu_seconds_total{instance=~\"$node\", mode=\"idle\"}[5m])) by (instance)) * 100",
          "refId": "A"
        }
      ],
      "title": "CPU 사용률",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "max": 100, "min": 0, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": 0 }, { "color": "orange", "value": 80 }, { "color": "red", "value": 90 } ] }, "unit": "percent" }
      },
      "gridPos": { "h": 9, "w": 6, "x": 6, "y": 0 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes{instance=~\"$node\"} / node_memory_MemTotal_bytes{instance=~\"$node\"})) * 100",
          "refId": "A"
        }
      ],
      "title": "RAM 사용률",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "max": 100, "min": 0, "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": 0 }, { "color": "red", "value": 60 } ] }, "unit": "percent" }
      },
      "gridPos": { "h": 9, "w": 6, "x": 12, "y": 0 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "((node_memory_SwapTotal_bytes{instance=~\"$node\"} - node_memory_SwapFree_bytes{instance=~\"$node\"}) / node_memory_SwapTotal_bytes{instance=~\"$node\"} * 100) or vector(0)",
          "refId": "A"
        }
      ],
      "title": "SWAP 사용률",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "gridPos": { "h": 9, "w": 6, "x": 18, "y": 0 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "(1 - (node_filesystem_avail_bytes{instance=~\"$node\", mountpoint=\"/\", fstype!~\"tmpfs\"} / node_filesystem_size_bytes{instance=~\"$node\", mountpoint=\"/\", fstype!~\"tmpfs\"})) * 100",
          "refId": "A"
        }
      ],
      "title": "디스크 사용률 (/)",
      "type": "stat"
    }
  ],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
        "definition": "label_values(up{job=\"node-exporter-prometheus-node-exporter\"}, instance)",
        "includeAll": true,
        "label": "서버 선택",
        "multi": true,
        "name": "node",
        "options": [],
        "query": "label_values(up{job=\"node-exporter-prometheus-node-exporter\"}, instance)",
        "refresh": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "🖥️ 7팀 서버 (422 해결 최종본)",
  "uid": "infra-7th-resolved-v2",
  "version": 1
}